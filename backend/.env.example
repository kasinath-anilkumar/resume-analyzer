# =============================================================================
#  backend/.env.example  —  ENVIRONMENT TEMPLATE  (safe to commit)
# =============================================================================
#  HOW THE TWO FILES RELATE
#    .env          ->  Your REAL values. Gitignored, NEVER committed. The app
#                      reads this at startup (via dotenv).
#    .env.example  ->  THIS file. Placeholders + docs only, committed to git so
#                      the team knows which variables exist. No real secrets here.
#
#  FIRST-TIME SETUP
#    1. Copy this file:          cp .env.example .env
#    2. Fill in the [REQUIRED] values in .env (leave optional ones blank to use
#       the documented default).
#    3. Generate strong secrets:  openssl rand -base64 48
#    4. Create the DB schema:     npm run db:migrate      (needs DATABASE_URL)
#    5. Seed the first admin:     npm run seed:admin -- "Name" admin@co.com "pw"
#
#  Keep this file IN SYNC: when you add/rename an env var in code, document it
#  here too — but ONLY with a placeholder, never a real secret.
# =============================================================================


# --- Core --------------------------------------------------------------------
# Port the API listens on (Render/Vercel set this automatically in production).
PORT=5000
# 'production' in prod, 'development' locally, 'test' under the test runner.
# The startup secret checks are skipped ONLY when NODE_ENV=test.
NODE_ENV=


# --- Auth & encryption secrets ----------------------------------------------
# [REQUIRED] Signs all JWT sessions. The server REFUSES TO START if this is
# missing, under 32 chars, or a known placeholder. Use a HIGH-ENTROPY random
# value — NOT dictionary words. Generate with:  openssl rand -base64 48
JWT_SECRET=supersecretjwtkeyforresumeanalyzerenterpriseats2026
# [STRONGLY RECOMMENDED] Separate key that encrypts stored provider tokens
# (AI / Meta / WhatsApp) at rest. Keep it DISTINCT from JWT_SECRET so one leaked
# secret can't both forge sessions AND decrypt tokens. If left blank, encryption
# falls back to JWT_SECRET. After setting it, run:  npm run reencrypt-secrets
SETTINGS_ENC_KEY=
# Only during a key rotation: the PREVIOUS SETTINGS_ENC_KEY, so already-stored
# secrets keep decrypting until `npm run reencrypt-secrets` re-encrypts them.
SETTINGS_ENC_KEY_OLD=


# --- Supabase: database + résumé storage -------------------------------------
# The backend uses Supabase Postgres for ALL data (via @supabase/supabase-js)
# and the same project's Storage for résumé files.
#   1. Create a Supabase project.
#   2. Run backend/db/schema.sql in the SQL Editor (or `npm run db:migrate`).
#   3. Create a PRIVATE storage bucket named to match SUPABASE_BUCKET. Résumés
#      are PII — the app never exposes public URLs; it serves short-lived signed
#      URLs from authenticated endpoints. See OPERATIONS.md.
#
# [REQUIRED] Project URL. Supabase -> Project Settings -> API -> Project URL.
SUPABASE_URL=https://your-project.supabase.co
# [REQUIRED] Service-role key — bypasses RLS, so it is server-side ONLY and must
# never reach the browser. Supabase -> Project Settings -> API -> service_role.
# (SUPABASE_KEY is accepted as an alias if you prefer that name.)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Storage bucket name for résumés (must match the PRIVATE bucket you created).
SUPABASE_BUCKET=resume
# [REQUIRED for `npm run db:migrate`] Direct Postgres connection string used by
# the migration script. Supabase -> Project Settings -> Database -> Connection
# string (URI). e.g. postgresql://postgres.<ref>:<password>@<host>:5432/postgres
DATABASE_URL=


# --- Frontend URLs & CORS ----------------------------------------------------
# Comma-separated list of allowed frontend origins for CORS.
CLIENT_URL=
# CORS also trusts any *.vercel.app origin by default (for preview deploys).
# Set to 'false' in PRODUCTION to lock CORS down to exactly CLIENT_URL + localhost.
ALLOW_VERCEL_PREVIEWS=
# Public frontend URL used in emailed links (password reset). Falls back to the
# first CLIENT_URL origin, then localhost. e.g. https://your-app.vercel.app
APP_URL=


# --- AI provider (optional; can also be configured in-app via Settings) ------
# Engine used when no key is set in Settings: mock | openai | claude | gemini |
# nvidia. 'mock' = deterministic offline scoring, no API cost.
AI_PROVIDER=mock
OPENAI_API_KEY=
# Optional model override for OpenAI (uses a sensible default if blank).
OPENAI_MODEL=
CLAUDE_API_KEY=
# Optional model override for Claude (uses a sensible default if blank).
CLAUDE_MODEL=
GEMINI_API_KEY=
# Optional. Default gemini-2.0-flash (the 1.5 models were retired). Others:
# gemini-2.5-flash, gemini-flash-latest.
GEMINI_MODEL=
NVIDIA_API_KEY=
NVIDIA_NIM_MODEL=


# --- Email (optional; Resend). If unset, all emails are silently skipped. -----
# Powers notification broadcasts, interview invites, and password-reset links.
# onboarding@resend.dev only delivers to your own Resend account email — verify
# a domain to email candidates/users. Put the REAL key in .env, not here.
RESEND_API_KEY=
EMAIL_FROM=


# --- Background worker -------------------------------------------------------
# Set to 'false' on the WEB service when you run the analysis worker as a
# SEPARATE process (`npm run worker`), so the queue isn't drained twice.
RUN_WORKER=


# --- Geocoding (optional) ----------------------------------------------------
# Provider for location search / candidate distance filtering. Default:
# openstreetmap (no API key needed).
GEOCODER_PROVIDER=


# --- First admin (optional; used by `npm run seed:admin` if args are omitted) -
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
