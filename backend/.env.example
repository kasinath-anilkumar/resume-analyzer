# =============================================================================
#  backend/.env.example — every variable the backend reads.
#  Copy to backend/.env and fill in. NEVER commit the real .env (gitignored).
#
#  Legend:  [REQUIRED] refuses to boot without it
#           [PROD]     required only when NODE_ENV=production
#           [OPTIONAL] has a working default; blank is fine
# =============================================================================

# --- Core --------------------------------------------------------------------
PORT=5000
# 'production' in prod, 'development' locally. NOTE: setting 'production' turns
# on the CLIENT_URL/APP_URL boot checks below.
NODE_ENV=development

# --- Auth & encryption secrets -----------------------------------------------
# [REQUIRED] Signs JWT sessions AND quiz start-tickets. Must be >=32 chars and
# not a known placeholder, or the server exits at startup.
#   generate:  openssl rand -base64 48
JWT_SECRET=

# [RECOMMENDED] Distinct key encrypting provider credentials in the settings row.
# Blank -> falls back to JWT_SECRET, so one leak compromises both. Set it.
SETTINGS_ENC_KEY=
# [OPTIONAL] Only during a key rotation: the PREVIOUS SETTINGS_ENC_KEY, so
# already-encrypted values can still be read. Clear once re-encryption is done.
SETTINGS_ENC_KEY_OLD=

# --- Supabase: database + résumé storage -------------------------------------
# [REQUIRED] e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# [REQUIRED] service_role key — SERVER-SIDE ONLY, never ship to a browser.
# (SUPABASE_KEY is accepted as a legacy alias if this is unset.)
SUPABASE_SERVICE_ROLE_KEY=
# [REQUIRED] Storage bucket holding résumés. MUST be set to Private in the
# Supabase dashboard — the app only ever hands out short-lived signed URLs.
SUPABASE_BUCKET=resumes
# [REQUIRED for `npm run db:migrate`] Direct Postgres connection string.
# Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL=

# --- Frontend URLs & CORS ----------------------------------------------------
# [PROD] Comma-separated frontend origin(s) allowed by CORS. Blank in production
# means ONLY localhost is allowed, so the real frontend is blocked on every
# request — the server refuses to start rather than serve that.
#   e.g. https://careers.yourdomain.com,https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# [PROD] Public frontend URL used to build password-reset links in emails. Blank
# in production means every reset email points at localhost and is unusable.
APP_URL=http://localhost:5173

# [OPTIONAL] 'true' also trusts any *.vercel.app origin (handy for preview
# deploys). Set 'false' in production and pin CLIENT_URL to your real domain(s).
ALLOW_VERCEL_PREVIEWS=false

# --- AI provider -------------------------------------------------------------
# The AI key is normally managed IN-APP (Settings → AI), stored encrypted in the
# database. These env vars are only a FALLBACK, and are used solely when
# AI_PROVIDER matches and the matching key below is non-empty.
# One of: mock | openai | claude | gemini | nvidia
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=
CLAUDE_API_KEY=
CLAUDE_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
NVIDIA_API_KEY=
NVIDIA_NIM_MODEL=

# --- Email (optional; Resend) ------------------------------------------------
# Unset -> every send is a graceful no-op and the app keeps working, but
# password resets and interview invites will not be delivered.
RESEND_API_KEY=
# Verified sender, e.g. "PARAKKAT ATS <hiring@yourdomain.com>"
EMAIL_FROM=

# --- Background worker -------------------------------------------------------
# [OPTIONAL] Anything other than 'false' runs the résumé-analysis worker
# in-process. Set 'false' on the web service ONLY when running `npm run worker`
# as a separate service, so the queue isn't drained from two places at once.
RUN_WORKER=

# --- Geocoding (optional) ----------------------------------------------------
# [OPTIONAL] Defaults to 'openstreetmap'.
GEOCODER_PROVIDER=

# --- First admin (used by `npm run seed:admin` only) -------------------------
# Read once when seeding the initial Admin login. Change the password after the
# first sign-in; these are not used at runtime.
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
