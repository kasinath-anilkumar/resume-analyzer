PORT=5000

# --- Database + storage (Supabase) ---
# The backend uses Supabase Postgres for ALL data via @supabase/supabase-js,
# plus the same project's Storage for resume files.
# Setup:
#   1. Create a Supabase project.
#   2. Run backend/db/schema.sql in the Supabase SQL Editor to create the tables.
#   3. Create a PUBLIC storage bucket (name it to match SUPABASE_BUCKET below).
#   4. Fill in SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY.
#   5. Seed the first admin (public sign-up is disabled):
#        npm run seed:admin -- "Full Name" admin@company.com "StrongPassword"

# Set to false on the WEB service when you run the analysis worker as a SEPARATE
# process (`npm run worker`) — otherwise the queue is drained in two places.
RUN_WORKER=
JWT_SECRET=change-me-to-a-long-random-string
# RECOMMENDED: a dedicated secret (distinct from JWT_SECRET) for encrypting stored
# provider tokens (AI / Meta / WhatsApp) at rest. Keeping it separate means a
# leaked JWT_SECRET can't also decrypt those tokens. If you introduce it AFTER
# secrets were already saved, decrypt automatically falls back to JWT_SECRET, then
# run `npm run reencrypt-secrets` to upgrade them to this key.
SETTINGS_ENC_KEY=
# Only during a key rotation: set to the PREVIOUS SETTINGS_ENC_KEY so already-
# stored secrets still decrypt until `npm run reencrypt-secrets` re-encrypts them.
SETTINGS_ENC_KEY_OLD=
# Comma-separated list of extra allowed frontend origins for CORS
CLIENT_URL=
# Public frontend URL used in emailed links (password reset). Falls back to the
# first CLIENT_URL origin, then localhost. e.g. https://your-app.vercel.app
APP_URL=

# --- Supabase project credentials (database + resume storage) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=resume

# --- AI provider (optional; also configurable in-app via Settings) ---
AI_PROVIDER=mock
OPENAI_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=
# Override the Gemini model if needed (default: gemini-2.0-flash). The 1.5
# models were retired. Other options: gemini-2.5-flash, gemini-flash-latest.
GEMINI_MODEL=
NVIDIA_API_KEY=
NVIDIA_NIM_MODEL=

# --- Email (optional; Resend). If unset, all emails are silently skipped. ---
# Notification broadcasts, interview invites, and password-reset links are
# emailed when configured. Put the real key in .env (NOT here — this file is
# committed). onboarding@resend.dev only delivers to your own Resend account
# email; verify a domain to email candidates/users.
RESEND_API_KEY=
EMAIL_FROM=

# --- First admin (optional; used by npm run seed:admin if args omitted) ---
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
