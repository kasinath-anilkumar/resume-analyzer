# =============================================================================
#  frontend/.env.example — copy to frontend/.env and fill in.
#
#  IMPORTANT: Vite inlines VITE_* values into the PUBLIC bundle at BUILD time.
#  Anything here is readable by anyone who loads the site — never put a secret
#  in this file. Backend secrets belong in backend/.env.
#
#  Because these are baked in at build time, changing one requires a REBUILD;
#  editing it on the host afterwards has no effect until you redeploy.
# =============================================================================

# [REQUIRED] Origin of the backend API — no trailing slash, no /api suffix
# (services/api.js appends /api itself).
#   local:  http://localhost:5000
#   prod:   https://your-api.onrender.com
#
# The production build FAILS if this is unset, rather than silently falling back
# to localhost and shipping an app that cannot reach its own backend.
# In production set it in the Vercel project's Environment Variables.
VITE_API_URL=http://localhost:5000
